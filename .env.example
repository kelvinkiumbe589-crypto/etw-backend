# ── Copy to .env and fill in (never commit the real .env) ──

# MetaApi.cloud API token (from https://app.metaapi.cloud → Token management)
METAAPI_TOKEN=

# Optional. Leave blank unless MetaApi told you a specific region, e.g. new-york / london / singapore
METAAPI_REGION=

# Firebase service-account JSON for the CLIENT'S Firebase project.
# Firebase console → Project settings → Service accounts → "Generate new private key".
# Paste the whole JSON on one line, OR base64-encode it and paste that.
FIREBASE_SERVICE_ACCOUNT=

# ── cTrader (Spotware Open API) — register an app at https://openapi.ctrader.com ──
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
# Must match the Redirect URI you set on the cTrader app, e.g.
# https://YOUR-SERVICE.onrender.com/api/ctrader/callback
CTRADER_REDIRECT_URI=

# TradeLocker & DXtrade need NO app key — users log in with their own credentials
# in the journal UI. (DXtrade's base URL is provided per-connect from the UI.)

# Local port (Render sets PORT automatically; ignored there)
PORT=8080
